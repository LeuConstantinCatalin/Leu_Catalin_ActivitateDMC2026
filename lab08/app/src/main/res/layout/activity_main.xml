<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Baza de date ROOM - Motoare"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tip motor (servo / stepper / dc)"
            android:inputType="text" />

        <EditText
            android:id="@+id/etPutere"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Putere"
            android:inputType="number"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etTensiune"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tensiune"
            android:inputType="number"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnInsert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Inserare motor"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnGetAll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Afiseaza toate"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etSearchTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tip exact pentru cautare"
            android:inputType="text"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnSearchByTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. Cauta dupa tip exact"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etMinPutere"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Putere minima"
            android:inputType="number"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/etMaxPutere"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Putere maxima"
            android:inputType="number"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnSearchByRange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="4. Cauta dupa interval de putere"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etDeleteValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Valoare tensiune"
            android:inputType="number"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnDeleteGreater"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="5. Sterge tensiune &gt; valoare"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnDeleteLess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="5. Sterge tensiune &lt; valoare"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etLetter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Litera de inceput"
            android:inputType="text"
            android:maxLength="1"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnIncrement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="6. Creste puterea cu 1"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lista motoare:"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"/>

        <ListView
            android:id="@+id/listViewMotors"
            android:layout_width="match_parent"
            android:layout_height="400dp" />

    </LinearLayout>
</ScrollView>