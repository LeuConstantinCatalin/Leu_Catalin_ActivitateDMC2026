<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grafic 2D"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="18dp"
            android:text="Configureaza valorile si alege tipul de chart care va fi desenat pe canvas."
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@color/text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card_surface"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date de intrare"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="14dp"
                android:text="Introdu cate valori vrei, apoi genereaza sliderele pentru fiecare parametru."
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/text_secondary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etNrParams"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_slider_card"
                    android:ems="6"
                    android:gravity="center_vertical"
                    android:hint="Numar valori"
                    android:inputType="number"
                    android:maxLength="2"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary" />

                <Button
                    android:id="@+id/btnCreateSliders"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_primary_button"
                    android:backgroundTint="@android:color/transparent"
                    android:paddingHorizontal="20dp"
                    android:text="Genereaza"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp"
                android:text="Tip de grafic"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgChartType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_slider_card"
                android:orientation="vertical"
                android:padding="12dp">

                <RadioButton
                    android:id="@+id/rbPie"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Pie Chart"
                    android:textColor="@color/text_primary" />

                <RadioButton
                    android:id="@+id/rbColumn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Column Chart"
                    android:textColor="@color/text_primary" />

                <RadioButton
                    android:id="@+id/rbBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bar Chart"
                    android:textColor="@color/text_primary" />
            </RadioGroup>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card_surface"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tvSlidersTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reglare valori"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"
                android:text="Fiecare slider permite alegerea unei valori intre 0 si 100."
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/text_secondary" />

            <LinearLayout
                android:id="@+id/slidersContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSendIntent"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@drawable/bg_primary_button"
            android:backgroundTint="@android:color/transparent"
            android:text="Deschide graficul"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
